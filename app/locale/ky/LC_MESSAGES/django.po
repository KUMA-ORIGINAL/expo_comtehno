msgid "Главная"
msgstr "Башкы бет"

msgid "Регистрация"
msgstr "Катталуу"

msgid "Участникам"
msgstr "Катышуучуларга"

msgid "Забронировать стенд"
msgstr "Стенд брондоо"

msgid "Варианты стендов"
msgstr "Стенддердин варианттары"

msgid "Список участников"
msgstr "Катышуучулардын тизмеси"

msgid "Каталог"
msgstr "Каталог"

msgid "Посетителям"
msgstr "Көрүүчүлөргө"

msgid "Получить билет на выставку"
msgstr "Көргөзмөгө билет алуу"

msgid "Время и место проведения"
msgstr "Өткөрүлүү убактысы жана жайы"

msgid "Партнерам"
msgstr "Өнөктөштөргө"

msgid "Подать заявку на партнёрство"
msgstr "Өнөктөштүк үчүн өтүнмө берүү"

msgid "Партнёрские возможности"
msgstr "Өнөктөштүк мүмкүнчүлүктөрү"

msgid "Контакты"
msgstr "Байланыш"

msgid "Все права защищены"
msgstr "Бардык укуктар корголгон"

msgid "Регистрация на выставку"
msgstr "Көргөзмөгө катталуу"

msgid "Заполните регистрационную форму. Поля, помеченные звездочкой"
msgstr "Катталуу формасын толтуруңуз. Жылдызча менен белгиленген талаалар"

msgid "обязательны для заполнения"
msgstr "толтурууга милдеттүү"

msgid "Зарегистрироваться"
msgstr "Катталуу"

msgid "На главную"
msgstr "Башкы бетке"

msgid "Регистрация успешна"
msgstr "Катталуу ийгиликтүү"

msgid "Регистрация успешно завершена"
msgstr "Катталуу ийгиликтүү аяктады"

msgid "Спасибо за регистрацию на выставку ICEE. Мы ждём Вас 14–16 апреля 2026 в Манеже КГАФКиС!"
msgstr "ICEE көргөзмөсүнө катталууңуз үчүн рахмат! 2026-жылдын 14–16-апрелинде КГАФКиС Манежинде күтөбүз!"

msgid "Бейдж можно получить на стойке регистрации по предъявлении электронного билета."
msgstr "Бейджди электрондук билетти көрсөтүү менен катталуу столунда алууга болот."

msgid "Зарегистрировать ещё одного посетителя"
msgstr "Дагы бир көрүүчүнү каттатуу"

msgid "Международная специализированная выставка"
msgstr "Эл аралык адистештирилген көргөзмө"

msgid "Регистрация участников и посетителей"
msgstr "Катышуучуларды жана көрүүчүлөрдү каттоо"

msgid "международной специализированной выставки"
msgstr "эл аралык адистештирилген көргөзмөнүн"

msgid "Для посещения мероприятия, пожалуйста, зарегистрируйтесь."
msgstr "Чарага катышуу үчүн, сураныч, катталыңыз."

msgid "Введите адрес Вашей электронной почты:"
msgstr "Электрондук почта дарегиңизди киргизиңиз:"

msgid "Ваш email"
msgstr "Сиздин email"

msgid "Продолжить"
msgstr "Улантуу"

msgid "У меня нет личного email, я хочу"
msgstr "Менин жеке emailим жок, мен"

msgid "связаться с организаторами"
msgstr "уюштуруучулар менен байланышууну"

msgid "На указанный email после регистрации придёт письмо с билетом."
msgstr "Катталуудан кийин көрсөтүлгөн emailге билет менен кат келип калат."

msgid "Изменить email"
msgstr "Email өзгөртүү"

msgid "На этот email уже зарегистрировались. Используйте другой адрес или свяжитесь с организаторами."
msgstr "Бул email менен мурунтан катталынган. Башка дарек колдонуңуз же уюштуруучулар менен байланышыңыз."

msgid "возможно несколько вариантов ответа"
msgstr "бир нече жооп берүүгө болот"

msgid "Удерживайте Ctrl (Cmd на Mac) для выбора нескольких вариантов"
msgstr "Бир нече вариант тандоо үчүн Ctrl (Mac'та Cmd) басып туруңуз"

msgid "Приобрести продукцию/услуги"
msgstr "Продукция/кызмат сатып алуу"

msgid "Получить информацию о продукции"
msgstr "Продукция жөнүндө маалымат алуу"

msgid "Найти новых поставщиков"
msgstr "Жаңы жеткирүүчүлөрдү табуу"

msgid "Поддержать существующие деловые контакты"
msgstr "Бар болгон ишкердик байланыштарды колдоо"

msgid "Посетить семинар/конференцию/мастер-класс"
msgstr "Семинар/конференция/мастер-класска катышуу"

msgid "Пообщаться с коллегами"
msgstr "Коллегалар менен сүйлөшүү"

msgid "Мы рады вашему интересу к международной выставке ICEE. Сегодня выставка представляет собой уникальную площадку для делового сотрудничества и изучения современных инноваций и новых технологий. Ведь выставки способны перенести человека в другой мир, собрав под одной крышей всё лучшее, что есть в отрасли или в личных интересах."
msgstr "ICEE эл аралык көргөзмөсүнө болгон кызыгууңузга кубанычтабыз. Бүгүн көргөзмө ишкердик кызматташуу жана заманбап инновациялар менен жаңы технологияларды изилдөө үчүн уникалдуу аянтча болуп саналат. Көргөзмөлөр бир тармактагы эң мыкты нерселерди бир чатырдын астына чогултуп, адамды башка дүйнөгө жетелей алат."

msgid "Регистрация ОБЯЗАТЕЛЬНА для всех посетителей."
msgstr "Бардык көрүүчүлөр үчүн катталуу МИЛДЕТТҮҮ."

msgid "Вход на выставку предоставляется БЕСПЛАТНО! Основанием для входа является именной бейдж. Бейдж выдается на стойке регистрации в фойе и действителен в течение всего периода работы выставки. Выставка работает с 10:00 до 18:00 первые два дня, третий день с 10:00 до 16:00. Вход посетителей прекращается за 30 минут до закрытия."
msgstr "Көргөзмөгө кирүү АКЫСЫЗ! Кирүү үчүн негиз — аты-жөнү жазылган бейдж. Бейдж фойедеги каттоо текчесинен берилет жана көргөзмө иштеген бүткүл мезгилде жарактуу. Көргөзмө алгачкы эки күн 10:00дөн 18:00гө чейин, үчүнчү күнү 10:00дөн 16:00гө чейин иштейт. Көрүүчүлөрдү киргизүү жабылууга 30 мүнөт калганда токтотулат."

msgid "Бейдж можно получить по предъявлении распечатанного или электронного билета после онлайн-регистрации на официальном сайте, а также пройти регистрацию в фойе в день посещения."
msgstr "Бейджди расмий сайтта онлайн катталгандан кийин басылган же электрондук билетти көрсөтүп алсаңыз болот, же барган күнү фойеде катталсаңыз болот."

msgid "Вход на конференции и семинары осуществляется по бейджам посетителя БЕСПЛАТНО!"
msgstr "Конференцияларга жана семинарларга кирүү көрүүчүнүн бейджи менен АКЫСЫЗ!"

msgid "Студенты профильных ВУЗов допускаются в третий день выставки только в сопровождении преподавателя, согласно списку (официально заверенному администрацией ВУЗа). Список должен быть согласован с организатором. ВУЗ может обратиться: +996 770 090 919 (WA) Арина Алейникова."
msgstr "Тиешелүү ЖОЖдордун студенттери көргөзмөнүн үчүнчү күнү гана окутуучунун коштоосунда, ЖОЖ администрациясы расмий тастыктаган тизмеге ылайык киргизилет. Тизме уюштуруучу менен макулдашылышы керек. ЖОЖ үчүн байланыш: +996 770 090 919 (WA) Арина Алейникова."

msgid "Посещение лицами до 18 лет возможно только при сопровождении совершеннолетних (родителей)."
msgstr "18 жашка чейинкилерге чоңдор (ата-энеси) коштогондо гана кирүүгө уруксат."

msgid "Передача бейджей третьим лицам запрещена. Организатор вправе проверить соответствие данных в бейдже документу, удостоверяющему личность."
msgstr "Бейджди үчүнчү жактарга берүүгө тыюу салынат. Уюштуруучу бейдждеги маалыматтын жеке күбөлүккө шайкештигин текшерүүгө укуктуу."

msgid "На территории выставки запрещены торговля, распространение рекламной продукции, презентации и агитация без письменного согласия организатора."
msgstr "Көргөзмө аймагында уюштуруучунун жазуу жүзүндөгү макулдугусуз соода, жарнамалык материалдарды таратуу, презентация жана үгүт жүргүзүүгө тыюу салынат."

msgid "Организатор не несёт ответственности за утерю личных вещей."
msgstr "Уюштуруучу жеке буюмдардын жоголушуна жооп бербейт."

msgid "При утрате бейджа обратитесь на стойку регистрации для его восстановления."
msgstr "Бейдж жоголсо, калыбына келтирүү үчүн каттоо текчесине кайрылыңыз."

msgid "Приятного посещения выставки!"
msgstr "Көргөзмөгө жагымдуу сапар каалайбыз!"

msgid "ICEE-000123 или https://.../ticket/..."
msgstr "ICEE-000123 же https://.../ticket/..."

msgid "Электронный билет участника выставки"
msgstr "Көргөзмө катышуучусунун электрондук билети"

msgid "здравствуйте!"
msgstr "саламатсызбы!"

msgid "Вы успешно зарегистрированы на международную выставку"
msgstr "Сиз эл аралык көргөзмөгө ийгиликтүү катталдыңыз"

msgid "Откройте билет по кнопке ниже и покажите его на входе в электронном или распечатанном виде."
msgstr "Төмөнкү баскыч аркылуу билетти ачып, кире бериште электрондук же басылган түрдө көрсөтүңүз."

msgid "Ваш персональный билет:"
msgstr "Сиздин жеке билетиңиз:"

msgid "Открыть билет"
msgstr "Билетти ачуу"

msgid "Даты проведения:"
msgstr "Өткөрүү күндөрү:"

msgid "Время работы:"
msgstr "Иштөө убактысы:"

msgid "14–15 апреля — 10:00–18:00, 16 апреля — 10:00–16:00"
msgstr "14–15-апрель — 10:00–18:00, 16-апрель — 10:00–16:00"

msgid "Место проведения:"
msgstr "Өтүү жери:"

msgid "Подробнее о компаниях-участниках:"
msgstr "Катышуучу компаниялар тууралуу кененирээк:"

msgid "С уважением, оргкомитет ICEE"
msgstr "Урматтоо менен, ICEE уюштуруу комитети"

msgid "все права защищены."
msgstr "бардык укуктар корголгон."

msgid "Выставка"
msgstr "Көргөзмө"

msgid "14–16 апреля 2026"
msgstr "2026-жылдын 14–16-апрели"

msgid "г. Бишкек, Манеж КГАФКиС"
msgstr "Бишкек ш., КГАФКиС манежи"

msgid "Предварительная регистрация"
msgstr "Алдын ала каттоо"

msgid "избавит Вас от необходимости стоять в очереди у регистрационной стойки и значительно сэкономит время."
msgstr "сизди каттоо текчесиндеги кезек күтүүдөн бошотуп, убактыңызды кыйла үнөмдөйт."

msgid "На один электронный адрес возможно получить только один билет."
msgstr "Бир электрондук дарекке бир гана билет алууга болот."

msgid "Электронный билет является индивидуальным и даёт право посетить мероприятие только его владельцу."
msgstr "Электрондук билет жеке болуп саналат жана иш-чарага анын ээсине гана кирүүгө укук берет."

msgid "Цифры и факты"
msgstr "Сандар жана фактылар"

msgid "дня выставки"
msgstr "көргөзмө күнү"

msgid "время работы"
msgstr "иштөө убактысы"

msgid "вход бесплатный"
msgstr "кирүү акысыз"

msgid "О выставке"
msgstr "Көргөзмө жөнүндө"

msgid "Условия посещения"
msgstr "Кирүү шарттары"

msgid "Контактное лицо"
msgstr "Байланыш адамы"

msgid "Арина Алейникова"
msgstr "Арина Алейникова"

msgid "Свяжитесь с нами по вопросам участия, регистрации и партнерства."
msgstr "Катышуу, катталуу жана өнөктөштүк боюнча биз менен байланышыңыз."

msgid "Организатор"
msgstr "Уюштуруучу"

msgid "Адрес"
msgstr "Дарек"
